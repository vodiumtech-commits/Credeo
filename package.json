{
  "name": "vodium-ledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=.env.local node_modules/.bin/prisma generate",
    "db:push": "node --env-file=.env.local node_modules/.bin/prisma db push",
    "db:migrate": "node --env-file=.env.local node_modules/.bin/prisma migrate dev",
    "db:deploy": "node --env-file=.env.local node_modules/.bin/prisma migrate deploy",
    "db:studio": "node --env-file=.env.local node_modules/.bin/prisma studio",
    "db:reset": "node --env-file=.env.local node_modules/.bin/prisma migrate reset",
    "seed": "node --env-file=.env.local node_modules/.bin/tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "pg": "^8.13.1",
    "posthog-js": "^1.187.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.52.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
