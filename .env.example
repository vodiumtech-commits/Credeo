# ============================================
# VODIUM LEDGER — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git — only this template file is safe to commit.
# ============================================

# --- Database (Supabase) ---
# DATABASE_URL  → pooler connection (Prisma Client at runtime)
# DIRECT_URL    → direct connection (Prisma CLI for migrations)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# --- Resend (email — OTP, newsletter, admin invites) ---
# Get from resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Meta Cloud API (WhatsApp Business) ---
# Get from developers.facebook.com → your app → WhatsApp → API Setup
#
# WHATSAPP_ACCESS_TOKEN    → the permanent System User token from Meta Business Suite
# WHATSAPP_PHONE_NUMBER_ID → the Phone Number ID shown in Meta WhatsApp dashboard
# WHATSAPP_VERIFY_TOKEN    → any random string YOU choose; paste the same value into Meta's
#                            Webhook Configuration page as the "Verify token"
# WHATSAPP_APP_SECRET      → from Meta App → Settings → Basic → App Secret
#
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_VERIFY_TOKEN="vodium-webhook-2026"
WHATSAPP_APP_SECRET="your_meta_app_secret"

# --- Vercel Cron ---
CRON_SECRET="your_random_cron_secret"

# --- Upstash Redis (rate limiting + OTP storage) ---
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# --- PostHog (product analytics) ---
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# --- Sentry (error monitoring) ---
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"

# --- Paystack (vendor subscription billing) ---
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret"

# --- App ---
NEXT_PUBLIC_APP_URL="https://vodiumledger.com"
NEXT_PUBLIC_BRAND_NAME="Vodium Ledger"

# --- Admin access ---
# IMPORTANT: change ADMIN_SECRET to a strong random string before going live
ADMIN_SECRET="change-this-before-going-live"
ADMIN_PHONES="+2348012345678"
