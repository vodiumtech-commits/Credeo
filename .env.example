# ============================================
# VODIUM LEDGER — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================

# --- Database (Supabase) ---
# DATABASE_URL  → pooler connection (Prisma Client at runtime)
# DIRECT_URL    → direct connection (Prisma CLI for migrations)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# --- Resend (email OTP delivery) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- SendPulse (WhatsApp Business API) ---
# Get these from sendpulse.com → API tab
SENDPULSE_API_USER_ID="your_sendpulse_user_id"
SENDPULSE_API_SECRET="your_sendpulse_api_secret"
SENDPULSE_WHATSAPP_BOT_ID="your_whatsapp_bot_id"
# Set this in SendPulse webhook config and copy it here
SENDPULSE_WEBHOOK_SECRET="your_webhook_secret_token"

# --- Vercel Cron ---
CRON_SECRET="your_random_cron_secret"

# --- Upstash Redis (rate limiting + OTP storage) ---
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# --- PostHog (product analytics) ---
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# --- Sentry (error monitoring) ---
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"

# --- Paystack (vendor subscription billing) ---
PAYSTACK_SECRET_KEY="your_paystack_secret_key"
PAYSTACK_PUBLIC_KEY="your_paystack_public_key"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_secret"

# --- App ---
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app/"
NEXT_PUBLIC_BRAND_NAME="Credeo"

# --- Admin access ---
ADMIN_SECRET="credeo"
ADMIN_PHONES="+2348012345678"
