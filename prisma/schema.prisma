// Vodium Ledger — Prisma schema
// Source of truth for the credit infrastructure data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────

model University {
  id        String   @id @default(cuid())
  name      String   @unique
  shortName String?  // e.g. "UNILAG", "OAU"
  city      String
  state     String
  status    UniversityStatus @default(PILOT)
  createdAt DateTime @default(now())

  vendors  Vendor[]
  students Student[]
}

enum UniversityStatus {
  PILOT
  ACTIVE
  PAUSED
}

model Vendor {
  id            String   @id @default(cuid())
  businessName  String
  ownerName     String
  phone         String   @unique
  email         String   @unique
  passwordHash  String
  vendorType    VendorType
  universityId  String
  university    University @relation(fields: [universityId], references: [id])
  campusLocation String?
  status        VendorStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credits       Credit[]
  subscription  VendorSubscription?
  scoreEvents   CreditScoreEvent[]

  @@index([universityId])
  @@index([phone])
  @@index([email])
}

enum VendorType {
  PROVISION_SHOP
  FOOD_CANTEEN
  LAUNDRY
  PRINTING
  BARBING_SALON
  HAIR_SALON
  PHARMACY
  MINI_MART
  OTHER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Student {
  id            String   @id @default(cuid())
  fullName      String
  matricNumber  String?
  phone         String   @unique
  universityId  String?
  university    University? @relation(fields: [universityId], references: [id])
  vodiumScore   Int      @default(500)  // 0–1000 scale, 500 = unscored baseline
  scoreUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credits       Credit[]
  scoreEvents   CreditScoreEvent[]

  @@index([universityId])
  @@index([phone])
  @@index([matricNumber])
}

// ─────────────────────────────────────────────
// CREDIT — the core transactional entity
// ─────────────────────────────────────────────

model Credit {
  id              String   @id @default(cuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  amount          Decimal  @db.Decimal(12, 2)  // ₦
  currency        String   @default("NGN")
  description     String?  // e.g. "Provisions", "Lunch x3"
  dateExtended    DateTime @default(now())
  dueDate         DateTime
  status          CreditStatus @default(OUTSTANDING)
  amountRepaid    Decimal  @default(0) @db.Decimal(12, 2)
  closedAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repayments      Repayment[]
  scoreEvents     CreditScoreEvent[]

  @@index([vendorId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

enum CreditStatus {
  OUTSTANDING       // money owed, not yet due
  DUE_SOON          // within 2 days of due date
  OVERDUE           // past due, not paid
  PARTIALLY_PAID    // some repayment received
  PAID              // fully repaid
  WRITTEN_OFF       // vendor wrote it off as a loss
}

model Repayment {
  id          String   @id @default(cuid())
  creditId    String
  credit      Credit   @relation(fields: [creditId], references: [id])
  amount      Decimal  @db.Decimal(12, 2)
  method      RepaymentMethod
  receivedAt  DateTime @default(now())
  notes       String?
  recordedBy  String?  // vendor user id (future)
  createdAt   DateTime @default(now())

  @@index([creditId])
}

enum RepaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  USSD
  MOBILE_MONEY
  OTHER
}

// ─────────────────────────────────────────────
// CREDIT SCORE GRAPH (the moat)
// ─────────────────────────────────────────────

model CreditScoreEvent {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  creditId    String?
  credit      Credit?  @relation(fields: [creditId], references: [id])
  eventType   ScoreEventType
  amount      Decimal? @db.Decimal(12, 2)
  scoreDelta  Int      // +/- impact on student's vodiumScore
  occurredAt  DateTime @default(now())

  @@index([studentId])
  @@index([vendorId])
  @@index([eventType])
}

enum ScoreEventType {
  CREDIT_EXTENDED
  PAID_ON_TIME
  PAID_LATE
  PAID_PARTIAL
  DEFAULTED
  WRITTEN_OFF
}

// ─────────────────────────────────────────────
// SUBSCRIPTION & BILLING
// ─────────────────────────────────────────────

model VendorSubscription {
  id              String   @id @default(cuid())
  vendorId        String   @unique
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(TRIAL)
  trialEndsAt     DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paystackCustomerId    String?
  paystackSubscriptionCode String?
  monthlyAmount   Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum SubscriptionPlan {
  STARTER       // ₦2,000/mo — up to 50 students
  GROWTH        // ₦5,000/mo — up to 200 students + scoring
  CAMPUS_PRO    // ₦10,000/mo — unlimited + analytics
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────
// WHATSAPP CONVERSATION STATE
// ─────────────────────────────────────────────

model WhatsAppSession {
  id              String   @id @default(cuid())
  phone           String   @unique  // E.164, includes whatsapp:+234...
  vendorId        String?
  state           WhatsAppState @default(IDLE)
  context         Json?    // free-form per-flow state
  lastInteractionAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phone])
}

enum WhatsAppState {
  IDLE
  ONBOARDING_NAME
  ONBOARDING_BUSINESS
  ONBOARDING_UNIVERSITY
  ADDING_CREDIT_STUDENT
  ADDING_CREDIT_AMOUNT
  ADDING_CREDIT_DUE
  MARKING_PAID
  LOOKING_UP_SCORE
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorType   String   // "vendor" | "system" | "admin"
  actorId     String?
  action      String   // e.g. "credit.created", "repayment.recorded"
  entityType  String?  // e.g. "Credit", "Repayment"
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
