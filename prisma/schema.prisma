// Vodium Ledger — Prisma schema
// Source of truth for the credit infrastructure data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────

model Community {
  id        String           @id @default(cuid())
  name      String           @unique   // always stored lowercase — used for all upsert lookups
  shortName String?                    // optional short code e.g. "UNILAG", "Yaba"
  city      String
  state     String
  status    CommunityStatus @default(PILOT)
  createdAt DateTime         @default(now())

  vendors  Vendor[]
  students Student[]
  organizations Organization[]
}

// ─────────────────────────────────────────────
// ORGANIZATIONS / ENTERPRISE TENANTS
// ─────────────────────────────────────────────

model Organization {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  type        OrganizationType   @default(SOLO_VENDOR)
  status      OrganizationStatus @default(TRIAL)
  trialEndsAt DateTime?
  plan        OrganizationPlan   @default(FREE)
  logoUrl     String?
  brandColor  String?
  // Reminder preferences — the merchant decides whether we message their customers.
  preDueRemindersEnabled  Boolean @default(true)
  overdueRemindersEnabled Boolean @default(true)
  communityId String?
  community   Community?         @relation(fields: [communityId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  branches    Branch[]
  vendors     Vendor[]
  students    Student[]
  credits     Credit[]
  bnplOrders  BnplOrder[]
  paymentMandates PaymentMandate[]
  couponCampaigns CouponCampaign[]
  couponRedemptions CouponRedemption[]
  ledgerEntries WalletLedgerEntry[]
  members     OrganizationMembership[]
  domains     TenantDomain[]
  whatsAppChannels WhatsAppChannel[]
  whatsAppSessions WhatsAppSession[]
  products    Product[]
  invoices    Invoice[]

  @@index([type])
  @@index([status])
  @@index([communityId])
}

enum OrganizationType {
  SOLO_VENDOR
  SUPERMARKET
  ENTERPRISE
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum OrganizationPlan {
  FREE
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

model Branch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  code           String
  phone          String?
  address        String?
  city           String?
  state          String?
  status         BranchStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  vendors        Vendor[]
  credits        Credit[]
  memberships    OrganizationMembership[]
  bnplOrders     BnplOrder[]
  couponCampaigns CouponCampaign[]
  ledgerEntries  WalletLedgerEntry[]
  products       Product[]
  invoices       Invoice[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  vendorId       String
  vendor         Vendor           @relation(fields: [vendorId], references: [id])
  branchId       String?
  branch         Branch?          @relation(fields: [branchId], references: [id])
  role           OrganizationRole @default(BRANCH_STAFF)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, vendorId])
  @@index([organizationId])
  @@index([vendorId])
  @@index([branchId])
  @@index([role])
}

enum OrganizationRole {
  OWNER
  HQ_ADMIN
  BRANCH_MANAGER
  BRANCH_STAFF
  FINANCE
  AUDITOR
}

model TenantDomain {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  host           String       @unique
  status         DomainStatus @default(PENDING)
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum DomainStatus {
  PENDING
  VERIFIED
  DISABLED
}

model WhatsAppChannel {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id])
  displayName    String
  phoneNumber    String?
  phoneNumberId  String?               @unique
  businessAccountId String?
  accessTokenRef String?               // name of an env var holding the token (env-first strategy)
  accessTokenEnc String?               // AES-256-GCM encrypted access token (never plaintext)
  status         WhatsAppChannelStatus @default(TEST)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  sessions       WhatsAppSession[]

  @@index([organizationId])
  @@index([status])
}

enum WhatsAppChannelStatus {
  TEST
  ACTIVE
  DISABLED
}

enum CommunityStatus {
  PILOT
  ACTIVE
  PAUSED
}

model Vendor {
  id            String   @id @default(cuid())
  businessName  String
  ownerName     String
  phone         String   @unique
  email         String   @unique
  passwordHash  String
  vendorType    VendorType
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id])
  communityId  String
  community    Community @relation(fields: [communityId], references: [id])
  location      String?
  status        VendorStatus @default(ACTIVE)
  inviteToken          String?   @unique  // set when a staff member is invited; cleared on accept
  inviteTokenExpiresAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credits       Credit[]
  subscription  VendorSubscription?
  scoreEvents   CreditScoreEvent[]
  notifications Notification[]
  memberships   OrganizationMembership[]
  bnplOrders    BnplOrder[]
  ledgerEntries WalletLedgerEntry[]
  invoices      Invoice[]

  @@index([communityId])
  @@index([organizationId])
  @@index([branchId])
  @@index([phone])
  @@index([email])
}

enum VendorType {
  PROVISION_SHOP
  FOOD_CANTEEN
  LAUNDRY
  PRINTING
  BARBING_SALON
  HAIR_SALON
  PHARMACY
  MINI_MART
  OTHER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Student {
  id            String   @id @default(cuid())
  fullName      String
  matricNumber  String?
  phone         String   @unique
  communityId   String?
  community     Community? @relation(fields: [communityId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  vodiumScore   Int      @default(500)  // 0–1000 scale, 500 = unscored baseline
  scoreUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credits       Credit[]
  scoreEvents   CreditScoreEvent[]
  bnplOrders    BnplOrder[]
  paymentMandates PaymentMandate[]
  couponRedemptions CouponRedemption[]
  invoices      Invoice[]

  @@index([communityId])
  @@index([organizationId])
  @@index([phone])
  @@index([matricNumber])
}

// ─────────────────────────────────────────────
// CREDIT — the core transactional entity
// ─────────────────────────────────────────────

model Credit {
  id              String   @id @default(cuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  branchId        String?
  branch          Branch? @relation(fields: [branchId], references: [id])
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  amount          Decimal  @db.Decimal(12, 2)  // ₦
  currency        String   @default("NGN")
  description     String?  // e.g. "Provisions", "Lunch x3"
  dateExtended    DateTime @default(now())
  dueDate         DateTime
  status          CreditStatus @default(OUTSTANDING)
  amountRepaid    Decimal  @default(0) @db.Decimal(12, 2)
  closedAt        DateTime?
  notes           String?
  reminderSentAt        DateTime?      // set when a pre-due reminder is dispatched
  overdueReminderSentAt DateTime?      // set when the latest overdue reminder is dispatched
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repayments      Repayment[]
  scoreEvents     CreditScoreEvent[]
  bnplOrders      BnplOrder[]

  @@index([vendorId])
  @@index([organizationId])
  @@index([branchId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@index([overdueReminderSentAt])
}

enum CreditStatus {
  OUTSTANDING       // money owed, not yet due
  DUE_SOON          // within 2 days of due date
  OVERDUE           // past due, not paid
  PARTIALLY_PAID    // some repayment received
  PAID              // fully repaid
  WRITTEN_OFF       // vendor wrote it off as a loss
}

model Repayment {
  id          String   @id @default(cuid())
  creditId    String
  credit      Credit   @relation(fields: [creditId], references: [id])
  amount      Decimal  @db.Decimal(12, 2)
  method      RepaymentMethod
  receivedAt  DateTime @default(now())
  notes       String?
  recordedBy  String?  // vendor user id (future)
  createdAt   DateTime @default(now())

  @@index([creditId])
}

// ─────────────────────────────────────────────
// BNPL, COUPONS, PAYMENT MANDATES & LEDGER
// ─────────────────────────────────────────────

model BnplOrder {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  vendorId        String
  vendor          Vendor       @relation(fields: [vendorId], references: [id])
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id])
  creditId        String?
  credit          Credit?      @relation(fields: [creditId], references: [id])
  orderNumber     String
  status          BnplOrderStatus @default(DRAFT)
  subtotal        Decimal      @db.Decimal(12, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal      @db.Decimal(12, 2)
  downPayment     Decimal      @default(0) @db.Decimal(12, 2)
  currency        String       @default("NGN")
  dueDate         DateTime
  termsAcceptedAt DateTime?
  couponCode      String?
  paymentReference String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           BnplOrderItem[]
  schedules       RepaymentSchedule[]
  couponRedemptions CouponRedemption[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([branchId])
  @@index([vendorId])
  @@index([studentId])
  @@index([creditId])
  @@index([status])
  @@index([dueDate])
}

enum BnplOrderStatus {
  DRAFT
  ACTIVE
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  WRITTEN_OFF
}

model BnplOrderItem {
  id          String    @id @default(cuid())
  orderId     String
  order       BnplOrder @relation(fields: [orderId], references: [id])
  name        String
  sku         String?
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())

  @@index([orderId])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  name           String
  description    String?
  sku            String?
  price          Decimal      @db.Decimal(12, 2)
  imageUrl       String?      // primary image (kept in sync with imageUrls[0])
  imageUrls      String[]     @default([])
  active         Boolean      @default(true)
  bnplEligible   Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([active])
}

// ─────────────────────────────────────────────
// DIGITAL INVOICES
// ─────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  vendorId       String
  vendor         Vendor        @relation(fields: [vendorId], references: [id])
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("NGN")
  dueDate        DateTime
  notes          String?
  sentAt         DateTime?
  paidAt         DateTime?
  overdueReminderSentAt DateTime?  // throttles automated overdue reminders
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items          InvoiceItem[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([vendorId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name       String
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  @@index([invoiceId])
}

model RepaymentSchedule {
  id          String   @id @default(cuid())
  orderId     String
  order       BnplOrder @relation(fields: [orderId], references: [id])
  dueAt       DateTime
  amount      Decimal  @db.Decimal(12, 2)
  status      RepaymentScheduleStatus @default(PENDING)
  paidAt      DateTime?
  providerReference String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([dueAt])
}

enum RepaymentScheduleStatus {
  PENDING
  PAID
  FAILED
  OVERDUE
  CANCELLED
}

model PaymentMandate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  provider       PaymentProvider
  status         PaymentMandateStatus @default(PENDING)
  customerReference String?
  authorizationReference String?
  mandateReference String?
  reusable       Boolean      @default(false)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([studentId])
  @@index([provider])
  @@index([status])
}

enum PaymentProvider {
  PAYSTACK
  MANUAL
}

enum PaymentMandateStatus {
  PENDING
  ACTIVE
  FAILED
  REVOKED
  EXPIRED
}

model CouponCampaign {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  name           String
  code           String
  type           CouponDiscountType
  value          Decimal      @db.Decimal(12, 2)
  minimumSpend   Decimal?     @db.Decimal(12, 2)
  maxRedemptions Int?
  perCustomerLimit Int?
  startsAt       DateTime     @default(now())
  endsAt         DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions    CouponRedemption[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@index([active])
  @@index([endsAt])
}

enum CouponDiscountType {
  FIXED
  PERCENTAGE
}

model CouponRedemption {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  campaignId     String
  campaign       CouponCampaign @relation(fields: [campaignId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  orderId        String?
  order          BnplOrder?   @relation(fields: [orderId], references: [id])
  amount         Decimal      @db.Decimal(12, 2)
  redeemedAt     DateTime     @default(now())

  @@index([organizationId])
  @@index([campaignId])
  @@index([studentId])
  @@index([orderId])
}

model WalletLedgerEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  vendorId       String?
  vendor         Vendor?      @relation(fields: [vendorId], references: [id])
  entryType      LedgerEntryType
  direction      LedgerDirection
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("NGN")
  sourceType     String
  sourceId       String?
  description    String?
  balanceAfter   Decimal?     @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([branchId])
  @@index([vendorId])
  @@index([entryType])
  @@index([createdAt])
}

enum LedgerEntryType {
  BNPL_ISSUED
  PAYMENT_RECEIVED
  COUPON_DISCOUNT
  REFUND
  ADJUSTMENT
  SETTLEMENT
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum RepaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  USSD
  MOBILE_MONEY
  OTHER
}

// ─────────────────────────────────────────────
// CREDIT SCORE GRAPH (the moat)
// ─────────────────────────────────────────────

model CreditScoreEvent {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  creditId    String?
  credit      Credit?  @relation(fields: [creditId], references: [id])
  eventType   ScoreEventType
  amount      Decimal? @db.Decimal(12, 2)
  scoreDelta  Int      // +/- impact on student's vodiumScore
  occurredAt  DateTime @default(now())

  @@index([studentId])
  @@index([vendorId])
  @@index([eventType])
}

enum ScoreEventType {
  CREDIT_EXTENDED
  PAID_ON_TIME
  PAID_LATE
  PAID_PARTIAL
  DEFAULTED
  WRITTEN_OFF
}

// ─────────────────────────────────────────────
// SUBSCRIPTION & BILLING
// ─────────────────────────────────────────────

model VendorSubscription {
  id              String   @id @default(cuid())
  vendorId        String   @unique
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(TRIAL)
  trialEndsAt     DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paystackCustomerId    String?
  paystackSubscriptionCode String?
  monthlyAmount   Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum SubscriptionPlan {
  STARTER       // ₦2,000/mo — up to 50 customers
  GROWTH        // ₦5,000/mo — up to 200 customers + scoring
  PRO           // ₦10,000/mo — unlimited + analytics
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────
// WHATSAPP CONVERSATION STATE
// ─────────────────────────────────────────────

model WhatsAppSession {
  id              String   @id @default(cuid())
  phone           String   @unique  // E.164, includes whatsapp:+234...
  vendorId        String?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  channelId       String?
  channel         WhatsAppChannel? @relation(fields: [channelId], references: [id])
  state           WhatsAppState @default(IDLE)
  context         Json?    // free-form per-flow state
  lastInteractionAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phone])
  @@index([organizationId])
  @@index([channelId])
}

enum WhatsAppState {
  IDLE
  ONBOARDING_NAME
  ONBOARDING_BUSINESS
  ONBOARDING_UNIVERSITY // legacy state kept so old sessions can recover cleanly
  ONBOARDING_COMMUNITY
  ADDING_CREDIT_STUDENT
  ADDING_CREDIT_PHONE
  ADDING_CREDIT_AMOUNT
  ADDING_CREDIT_DUE
  MARKING_PAID
  LOOKING_UP_SCORE
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  title       String
  message     String
  type        NotificationType @default(INFO)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([vendorId])
  @@index([read])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  DANGER
}

// ─────────────────────────────────────────────
// ADMIN TEAM
// ─────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  CFO
  CUSTOMER_CARE
  ANALYTICS
}

model AdminUser {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  role           AdminRole
  passwordHash   String?
  inviteToken    String?   @unique
  tokenExpiresAt DateTime?
  activatedAt    DateTime?
  lastLoginAt    DateTime?
  invitedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
  @@index([inviteToken])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorType   String   // "vendor" | "system" | "admin"
  actorId     String?
  action      String   // e.g. "credit.created", "repayment.recorded"
  entityType  String?  // e.g. "Credit", "Repayment"
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
